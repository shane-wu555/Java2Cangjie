# ================================================================
# Java2Cangjie 部署环境变量
# 修改 BASE_MODEL_HOST_PATH 为宿主机上基础模型的实际路径后执行：
#   docker compose --env-file .env up -d --build
# ================================================================

# 基础模型在宿主机上的存放路径（只读挂载到容器内 /models/base）
BASE_MODEL_HOST_PATH=D:/models/Qwen2.5-Coder-7B-Instruct

# 容器内模型路径（通常不需要修改）
BASE_MODEL_PATH=/models/base
LORA_PATH=/app/outputs/qwen2.5b-instruct-lora
