# 模型服务参数配置（示例）
# 复制此文件为 .env，然后修改对应路径

# 基础模型（本地路径或 HF hub 标识）
BASE_MODEL=qwen/Qwen-2.5B-instruct

# LoRA 输出目录（训练时使用）
LORA_OUTPUT=outputs/qwen2.5b-instruct-lora

# LoRA 权重路径（推理/服务时使用）
LORA_PATH=outputs/qwen2.5b-instruct-lora

# 国内镜像地址（可选，网络不稳定时使用）
HF_ENDPOINT=https://hf-mirror.com

# 示例（本地模型路径）：
# BASE_MODEL=D:\models\qwen-2.5b-instruct
# LORA_OUTPUT=outputs/qwen2.5b-instruct-lora
# LORA_PATH=outputs/qwen2.5b-instruct-lora
